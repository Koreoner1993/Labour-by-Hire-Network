# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_this_to_a_random_secret

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lbh

# ── HEDERA HTS ────────────────────────────────────────────────────────────────
# Your Hedera operator account (pays for transactions)
HEDERA_OPERATOR_ID=0.0.12345
# DER-encoded ED25519 private key from Hedera portal
HEDERA_OPERATOR_KEY=302e020100300506032b6570...
# testnet | mainnet
HEDERA_NETWORK=testnet
# Pre-created NFT token ID (type=NON_FUNGIBLE_UNIQUE)
HEDERA_TOKEN_ID=0.0.99999

# ── IPFS / PINATA ─────────────────────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
