# ─── Hedera ────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet                        # testnet | mainnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX               # Your platform Hedera account
HEDERA_OPERATOR_KEY=302e...                   # ED25519 private key (hex)

# ─── LBH Identity Token ─────────────────────────────────────────────────────
# Populated after first /api/identity/setup-token call
LBH_IDENTITY_TOKEN_ID=0.0.XXXXXXX

# ─── IPFS (NFT.Storage) ──────────────────────────────────────────────────────
# Free at nft.storage — create an account and generate an API key
NFT_STORAGE_KEY=eyJhbGciOi...

# ─── Your existing LBH env vars ─────────────────────────────────────────────
DATABASE_URL=...
STRIPE_SECRET_KEY=...
