# Production Environment Variables
NODE_ENV=production
JWT_SECRET=088c9baa-a906-42f4-b36b-ed8b44ac28dc
JWT_EXPIRY=15d
CORS_ORIGIN=*

# PostgreSQL Configuration (Railway sets these automatically)
# Alternatively use: DATABASE_URL=postgres://user:password@host:5432/labour_by_hire
DB_HOST=${DB_HOST:-localhost}
DB_PORT=${DB_PORT:-5432}
DB_NAME=${DB_NAME:-labour_by_hire}
DB_USER=${DB_USER:-postgres}
DB_PASSWORD=${DB_PASSWORD}
